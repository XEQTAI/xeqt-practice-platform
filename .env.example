# XEQT Practice Platform — Environment Variables
# Copy this to .env.local for local dev (NEVER commit .env.local)
# Set these as Cloudflare Pages environment variables in production

# Super admin credentials (set in Cloudflare Pages → Settings → Environment Variables)
XEQT_SUPER_USER=erik
XEQT_SUPER_PASS=your_password_here

# Practice passwords are set per-practice via the super admin panel
# and stored in Cloudflare KV (not in practices.json)
